<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.sportt5.controller.PlaylistController"
            visible="false" managed="false"
            fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="home-scroll">
    <VBox spacing="28.0" styleClass="playlist-body">

        <Label text="PLAYLISTS" styleClass="store-section-title" />

        <ScrollPane fitToHeight="true" hbarPolicy="NEVER" vbarPolicy="NEVER"
                    prefHeight="158.0" minHeight="158.0" maxHeight="158.0" styleClass="home-scroll">
            <HBox fx:id="playlistCardsBox" spacing="16.0" />
        </ScrollPane>

        <HBox alignment="CENTER_LEFT" spacing="32.0">
            <StackPane prefWidth="220.0" prefHeight="220.0" styleClass="playlist-hero-art">
                <Label text="▯" />
            </StackPane>
            <VBox spacing="12.0">
                <Label fx:id="playlistEyebrow" text="SELECT A PLAYLIST" styleClass="playlist-eyebrow" />
                <Label fx:id="playlistHeading" text="—" styleClass="playlist-heading" />
                <HBox spacing="10.0">
                    <Label fx:id="playlistSongCount" text="0 songs" styleClass="playlist-meta" />
                    <Label text="•" styleClass="playlist-meta" />
                    <Label fx:id="playlistDuration" text="" styleClass="playlist-meta" />
                </HBox>
            </VBox>
        </HBox>

        <HBox alignment="CENTER_LEFT" spacing="18.0">
            <Button text="▶" styleClass="playlist-play-button" />
            <Button text="Follow" styleClass="follow-button" />
            <Label text="•••" styleClass="row-action" />
        </HBox>

        <VBox styleClass="playlist-table" spacing="0.0">
            <HBox spacing="18.0" prefHeight="32.0">
                <Label text="#" styleClass="table-head" minWidth="40.0" maxWidth="40.0" />
                <Label text="" minWidth="32.0" maxWidth="32.0" />
                <Label text="TITLE" styleClass="table-head" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
                <Label text="ALBUM" styleClass="table-head" minWidth="180.0" maxWidth="180.0" />
                <Label text="DURATION" styleClass="table-head" minWidth="60.0" maxWidth="60.0" />
            </HBox>
            <VBox fx:id="songListVBox" spacing="0.0" />
        </VBox>

    </VBox>
</ScrollPane>
