            <HBox alignment="CENTER" spacing="0.0" styleClass="auth-tabs">
                <Button text="Login" onAction="#showLogin" styleClass="auth-tab" />
                <Button text="Sign Up" onAction="#showSignup" styleClass="auth-tab-active" />
