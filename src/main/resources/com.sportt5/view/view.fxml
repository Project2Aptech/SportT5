<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.sportt5.controller.AppController" prefWidth="1220.0" prefHeight="810.0" minWidth="1220.0" minHeight="810.0" maxWidth="1220.0" maxHeight="810.0" styleClass="main-scene">
