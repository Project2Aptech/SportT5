                                        <VBox spacing="3.0"><Label text="Glow On" styleClass="track-title" /><Label text="Turnstile" styleClass="track-artist" /></VBox>
                                        <Region HBox.hgrow="ALWAYS" /><Label text="♡" styleClass="row-action" /><Label text="•••" styleClass="row-action" />
                                    </HBox>
                                    <HBox alignment="CENTER_LEFT" spacing="18.0" styleClass="track-row">
                                        <Label text="03" styleClass="track-index" />
