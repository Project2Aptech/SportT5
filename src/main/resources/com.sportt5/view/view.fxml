        <VBox fx:id="loginCard" alignment="CENTER" spacing="13.0" prefWidth="430.0" maxWidth="430.0" styleClass="auth-card">
            <StackPane prefWidth="56.0" prefHeight="56.0" styleClass="auth-logo">
                <Label text="♪" />
            </StackPane>
            <VBox alignment="CENTER" spacing="4.0">
