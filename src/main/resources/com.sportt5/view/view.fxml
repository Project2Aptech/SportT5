<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" prefWidth="1280.0" prefHeight="1024.0" minWidth="1280.0" minHeight="1024.0" maxWidth="1280.0" maxHeight="1024.0" styleClass="main-scene">
